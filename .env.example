# Servidor
PORT=3000

# Base de datos (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=restoventas_app
DB_PASSWORD=
DB_NAME=restoventas
# En dev podes usar sincronizacion automatica de esquema (true). En prod: false + migraciones.
DB_SYNC=false

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# IA (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
